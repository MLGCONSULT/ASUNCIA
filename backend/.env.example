# ========== BACKEND .env ==========
# Copier ce fichier en .env puis remplir. Chaque variable indique où la trouver.

# --- App ---
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
ALLOW_VERCEL_PREVIEW_ORIGINS=false

# --- Sécurité HTTP / anti-abus (optionnel) ---
# Limite globale
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
# Limite routes sensibles (/api/auth, /api/chat, /api/mcp)
RATE_LIMIT_SENSITIVE_WINDOW_MS=60000
RATE_LIMIT_SENSITIVE_MAX_REQUESTS=30

# --- Supabase (obligatoire) ---
# Où : https://supabase.com/dashboard → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://fhtuzpzmeqbiqxbhyjpp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZodHV6cHptZXFiaXF4Ymh5anBwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzA5NzQwNDgsImV4cCI6MjA4NjU1MDA0OH0.d47Ojry7NI1QuMOjfHi3stm5CT0utCN7HzcQYrnGHOA
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZodHV6cHptZXFiaXF4Ymh5anBwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MDk3NDA0OCwiZXhwIjoyMDg2NTUwMDQ4fQ.3ZSAldR4OzYd3Ar_NBA0Cjjb5_hOOPK2gvNqxz-n-7w

# --- MCP Supabase (optionnel, pour l’assistant) ---
# Où : Supabase Dashboard → Settings → API → Personal Access Token (créer un token)
SUPABASE_ACCESS_TOKEN=sbp_xxxx
# Optionnel si déjà déduit depuis NEXT_PUBLIC_SUPABASE_URL
SUPABASE_PROJECT_REF=xxxxxxxxxxxx

# --- OpenAI (chat IA) ---
# Où : https://platform.openai.com/api-keys → Create secret key
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- MCP n8n ---
# Où : URL = l’URL de ton serveur n8n + /mcp-server/http (ex. https://n8n.example.com/mcp-server/http)
# Token = config du MCP dans n8n (token d’accès au serveur MCP)
N8N_MCP_URL=https://ton-n8n.example.com/mcp-server/http
N8N_MCP_ACCESS_TOKEN=ton_token_n8n

# --- MCP Gmail ---
# Où URL : l’URL de ton serveur MCP Gmail (celui qui expose list_messages, get_message, send_email)
# Où Google : https://console.cloud.google.com/apis/credentials → Créer des identifiants → ID client OAuth 2.0 (type Application Web, URI de redirection = https://ton-frontend/api/auth/gmail/callback)
GMAIL_MCP_URL=https://ton-gmail-mcp.example.com
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# --- MCP Airtable ---
# Choisir UN seul mode : oauth OU server-token (décommenter les lignes du mode choisi).
AIRTABLE_RUNTIME_MODE=oauth
AIRTABLE_MCP_URL=https://mcp.airtable.com/mcp
# Mode OAuth : Où : https://airtable.com/developers/app → ton app → OAuth → Client ID / Secret. Redirect = https://ton-backend/api/auth/airtable/callback
AIRTABLE_OAUTH_CLIENT_ID=
AIRTABLE_OAUTH_CLIENT_SECRET=
AIRTABLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/airtable/callback
# Mode server-token (alternative) : Où : Airtable → Account → Developer hub → Personal access token
# AIRTABLE_MCP_TOKEN=patxxx
# AIRTABLE_TOKEN=patxxx

# --- MCP Notion ---
# Choisir UN seul mode : oauth OU server-token (décommenter les lignes du mode choisi).
NOTION_RUNTIME_MODE=oauth
NOTION_MCP_URL=https://mcp.notion.com/mcp
# Mode OAuth : Où : https://www.notion.so/my-integrations → ton intégration → OAuth. Redirect = https://ton-backend/api/auth/notion/callback
NOTION_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/notion/callback
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
# Mode server-token (alternative) : Où : Notion → Settings & members → Connexions → Développeur → Créer une intégration → Token interne
# NOTION_MCP_TOKEN=secret_xxx
# NOTION_API_KEY=secret_xxx

# --- SMTP (optionnel) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
