# ========== FRONTEND .env ==========
# Copier ce fichier en .env puis remplir. Chaque variable indique où la trouver.

# --- Supabase (obligatoire) ---
# Où : https://supabase.com/dashboard → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# --- URLs ---
# URL du site (ex. en prod : https://ton-site.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# URL du backend (ex. en prod : https://ton-backend.vercel.app)
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# --- Gmail OAuth (obligatoire si tu utilises Gmail) ---
# Où : https://console.cloud.google.com/apis/credentials → même ID client OAuth que dans le backend (Application Web, URI de redirection = https://ton-frontend/api/auth/gmail/callback)
# Mettre les MÊMES valeurs que dans backend/.env (GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# --- Optionnel ---
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=
